# Telegram Bot Configuration

# Your Telegram Bot Token from BotFather
# Get it by messaging BotFather and running /newbot
# Format: 123456789:ABCDefGhijKlmnoPqrsTuvWxyz-1A2B3C4D
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Secret key for securing cron job endpoint
# Create any random string (at least 16 characters recommended)
# This prevents unauthorized access to the daily reminder endpoint
CRON_SECRET=your-super-secret-key-change-me-123
